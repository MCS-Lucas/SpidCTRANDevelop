@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.EntityFrameworkCore
@using Spid.Data
@inject UserSession UserSession
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager NavManager
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Spid</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <!-- CATEGORIA: ATESTE -->
        <div class="nav-category" @onclick="ToggleAteste">
            <span class="category-title">Ateste</span>
            <Icon Name="@(isAtesteOpen ? "chevron-down" : "chevron-up")" Size="12" Class="category-icon" />
        </div>

        <div class="nav-subcategory @(isAtesteOpen ? "expanded" : "collapsed")">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <Icon Name="house" Size="16" Class="nav-icon" /> Dashboard
                </NavLink>
            </div>
            @if (podeAnalisar)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="atestar-viagens">
                        <Icon Name="magnifying-glass-chart" Size="16" Class="nav-icon" /> Atestar Viagens
                    </NavLink>
                </div>
            }
        </div>

        <!-- CATEGORIA: GESTÃO -->
        <div class="nav-category mt-2" @onclick="ToggleGestao">
            <span class="category-title">Gestão</span>
            <Icon Name="@(isGestaoOpen ? "chevron-down" : "chevron-up")" Size="12" Class="category-icon" />
        </div>

        <div class="nav-subcategory @(isGestaoOpen ? "expanded" : "collapsed")">
            @if (podeImportar)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="importar-viagens">
                        <Icon Name="file-import" Size="16" Class="nav-icon" /> Importar Viagens
                    </NavLink>
                </div>
            }

            @if (isAdmin)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="usuarios">
                        <Icon Name="users-gear" Size="16" Class="nav-icon" /> Gerenciar Usuários
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="status-conferencias">
                        <Icon Name="clipboard-check" Size="16" Class="nav-icon" /> Status Conferências
                    </NavLink>
                </div>
            }

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="minhas-informacoes">
                    <Icon Name="user-pen" Size="16" Class="nav-icon" /> Minhas Informações
                </NavLink>
            </div>
        </div>

        <div class="nav-category mt-4 mb-4" @onclick="AbrirModalSuporte">
            <span class="category-title">CONTATO SUPORTE</span>
            <Icon Name="headset" Size="14" Class="category-icon" />
        </div>
    </nav>
</div>

@if (isModalSuporteAberto)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="color: #333;">
                <div class="modal-header text-white" style="background: linear-gradient(135deg, #1a73e8, #1557ad);">
                    <h5 class="modal-title">CONTATO SUPORTE</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharModalSuporte"></button>
                </div>
                <div class="modal-body text-center p-4">
                    <p class="mb-3">A funcionalidade de <strong>Abrir Chamados</strong> será adicionada em breve!</p>
                    <p class="mb-3">Enquanto isso, fale diretamente com o suporte pelos ramais:</p>
                    <h5 class="mb-1" style="color: #1a73e8; font-weight: 700;">6-3116 Dani</h5>
                    <h5 class="mb-0" style="color: #1a73e8; font-weight: 700;">6-3142 Flávia</h5>
                </div>
                <div class="modal-footer bg-light justify-content-center">
                    <button type="button" class="btn btn-primary px-4" @onclick="FecharModalSuporte" style="background: linear-gradient(135deg, #1a73e8, #1557ad); border: none;">Entendido</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool podeImportar;
    private bool podeAnalisar;
    private bool isAdmin;

    private bool isAtesteOpen = true; // Dashboard default
    private bool isGestaoOpen = false;
    private bool isModalSuporteAberto = false;

    protected override async Task OnInitializedAsync()
    {
        NavManager.LocationChanged += OnLocationChanged;
        CheckActiveMenu(NavManager.Uri);

        if (!UserSession.IsAuthenticated) return;

        var perfil = UserSession.UsuarioLogado!.Perfil;
        isAdmin = perfil == "Admin" || perfil.StartsWith("Gestor Central");

        // Usa contexto isolado via factory para evitar conflito com o AppDbContext
        // Scoped da página que está sendo renderizada ao mesmo tempo durante o SSR.
        await using var db = await DbFactory.CreateDbContextAsync();
        var permissoes = await db.PerfisRecurso
            .Where(pr => pr.Perfil == perfil)
            .Select(pr => pr.Recurso.Chave)
            .ToListAsync();

        podeImportar = permissoes.Contains("ImportarViagens");
        podeAnalisar = permissoes.Contains("AnalisarViagens") || perfil == "Admin" || perfil == "Gestor Central Ateste";
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        CheckActiveMenu(e.Location);
    }

    private void CheckActiveMenu(string url)
    {
        var relativeUrl = NavManager.ToBaseRelativePath(url).Split('?')[0].TrimEnd('/');

        if (relativeUrl == "" || relativeUrl == "atestar-viagens")
        {
            isAtesteOpen = true;
        }
        else if (relativeUrl == "importar-viagens" || relativeUrl == "usuarios" || relativeUrl == "status-conferencias" || relativeUrl == "minhas-informacoes")
        {
            isGestaoOpen = true;
        }
        InvokeAsync(StateHasChanged);
    }

    private void ToggleAteste() => isAtesteOpen = !isAtesteOpen;
    private void ToggleGestao() => isGestaoOpen = !isGestaoOpen;

    private void AbrirModalSuporte() => isModalSuporteAberto = true;
    private void FecharModalSuporte() => isModalSuporteAberto = false;

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }
}