@using Microsoft.EntityFrameworkCore
@using Spid.Data
@inject UserSession UserSession
@inject IDbContextFactory<AppDbContext> DbFactory

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Spid</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <Icon Name="house" Size="16" Class="nav-icon" /> Dashboard
            </NavLink>
        </div>

        @if (podeImportar)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="importar-viagens">
                    <Icon Name="file-import" Size="16" Class="nav-icon" /> Importar Viagens
                </NavLink>
            </div>
        }

        @if (isAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="usuarios">
                    <Icon Name="users-gear" Size="16" Class="nav-icon" /> Gerenciar Usuários
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="status-conferencias">
                    <Icon Name="clipboard-check" Size="16" Class="nav-icon" /> Status Conferências
                </NavLink>
            </div>
        }

        @if (podeAnalisar)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="analisar-viagens">
                    <Icon Name="magnifying-glass-chart" Size="16" Class="nav-icon" /> Atestar Viagens
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private bool podeImportar;
    private bool podeAnalisar;
    private bool isAdmin;

    protected override async Task OnInitializedAsync()
    {
        if (!UserSession.IsAuthenticated) return;

        var perfil = UserSession.UsuarioLogado!.Perfil;
        isAdmin = perfil == "Admin";

        // Usa contexto isolado via factory para evitar conflito com o AppDbContext
        // Scoped da página que está sendo renderizada ao mesmo tempo durante o SSR.
        await using var db = await DbFactory.CreateDbContextAsync();
        var permissoes = await db.PerfisRecurso
            .Where(pr => pr.Perfil == perfil)
            .Select(pr => pr.Recurso.Chave)
            .ToListAsync();

        podeImportar = permissoes.Contains("ImportarViagens");
        podeAnalisar = permissoes.Contains("AnalisarViagens");
    }
}