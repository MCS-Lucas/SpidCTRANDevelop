@page "/login"
@layout LoginLayout
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Authorization
@using Spid.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject UserSession UserSession
@inject NavigationManager Nav

<PageTitle>Login — SPID</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="text-center mb-3">
            <img src="spid_web.png" alt="SPID Logo" style="max-width: 180px; width: 100%;" />
        </div>
        <h2 class="text-center mb-2">SPID</h2>
        <p class="text-center text-muted mb-4">Sistema de Gestão de Viagens</p>

        @if (!string.IsNullOrEmpty(erroMensagem))
        {
            <div class="alert alert-danger" role="alert">
                @erroMensagem
            </div>
        }

        @*
            IMPORTANTE: Este form usa POST HTTP puro para /do-login.
            NÃO usar EditForm + SignInAsync aqui — o Blazor roda via WebSocket e
            não permite gravar cookies (cabeçalhos HTTP já foram enviados).
        *@
        <form method="post" action="/do-login" data-enhance="false">
            <div class="mb-3">
                <label for="ponto" class="form-label">Ponto</label>
                <input id="ponto" name="ponto" type="text" class="form-control" placeholder="Ex: 0001" required />
            </div>

            <div class="mb-3">
                <label for="senha" class="form-label">Senha</label>
                <input id="senha" name="senha" type="password" class="form-control" placeholder="Digite sua senha"
                       required />
            </div>

            <br /><br />
            <button type="submit" class="btn btn-primary w-100">
                Entrar
            </button>

            <br /><br />
            <a href="" class="text-center mb-2 d-block">Alterar Senha</a>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "erro")]
    public string? Erro { get; set; }

    private string? erroMensagem;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var isAuthenticated = user.Identity?.IsAuthenticated == true;

        if (isAuthenticated && !UserSession.IsAuthenticated)
        {
            await using var dbCtx = await DbFactory.CreateDbContextAsync();
            await UserSession.TryRestoreFromClaimsAsync(user, dbCtx);
        }

        if (isAuthenticated)
        {
            if (UserSession.UsuarioLogado?.ContadorAcessos == 0)
                Nav.NavigateTo("/primeiro-acesso");
            else
                Nav.NavigateTo("/");
        }
    }

    protected override void OnParametersSet()
    {
        erroMensagem = Erro switch
        {
            "campos" => "Preencha o ponto e a senha.",
            "usuario" => "Ponto não encontrado ou usuário inativo.",
            "senha" => "Senha incorreta.",
            _ => null
        };
    }
}
