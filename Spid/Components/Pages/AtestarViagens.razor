@page "/atestar-viagens"
@namespace Spid.Components.Pages
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@using Spid.Data
@using Spid.Services
@using Spid.Components.Shared
@inject AppDbContext Db
@inject UserSession UserSession
@inject NavigationManager Nav

<style>
    .btn-badge-contestada {
        transition: all 0.2s ease-in-out;
    }

    .btn-badge-contestada:hover {
        transform: scale(1.08) translateY(-1px);
        box-shadow: 0 4px 8px rgba(220, 53, 69, 0.35);
        filter: brightness(1.1);
    }

    .btn-badge-contestada:active {
        transform: scale(0.95);
    }
</style>

<PageTitle>Atestar Viagens — SPID</PageTitle>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <h3 class="mb-0">
        <Icon Name="magnifying-glass-chart" Size="24" Class="page-header-icon" /> Atestar Viagens
    </h3>

    @if (isAdmin && centrosCusto.Count > 0)
    {
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <select class="setor-select" @bind="centroCustoSelecionadoId" @bind:after="CarregarViagens" disabled="@(!isAdmin)">
                <option value="">Selecione o Centro de Custo</option>
                @foreach (var c in centrosCusto)
                {
                    <option value="@c.Id">@c.Nome</option>
                }
            </select>
        </div>
    }
</div>

@if (!temPermissao)
{
    <div class="alert alert-warning">Você não tem permissão para acessar esta funcionalidade.</div>
}
else if (viagens is null)
{
    <p class="text-muted">Carregando...</p>
}
else
{
    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex gap-3 align-items-end flex-wrap">
            <div>
                <label class="form-label small mb-1">Mês</label>
                <div class="d-flex align-items-center gap-1">
                    <button class="filter-btn" @onclick="MesAnterior" disabled="@(mesSelecionado <= 1)">&#9664;</button>
                    <select class="filter-select" @bind="mesSelecionado" @bind:after="CarregarViagens">
                        @for (int m = 1; m <= 12; m++)
                        {
                            var mes = m;
                            <option value="@mes">
                                @System.Globalization.CultureInfo.GetCultureInfo("pt-BR").DateTimeFormat.GetMonthName(mes)
                            </option>
                        }
                    </select>
                    <button class="filter-btn" @onclick="MesSeguinte" disabled="@(mesSelecionado >= 12)">&#9654;</button>
                </div>
            </div>
            <div>
                <label class="form-label small mb-1">Ano</label>
                <select class="filter-select" @bind="anoSelecionado" @bind:after="CarregarViagens">
                    @foreach (var a in anosDisponiveis)
                    {
                        <option value="@a">@a</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label small mb-1">Status</label>
                <select class="filter-select" @bind="filtroStatus" @bind:after="Filtrar">
                    <option value="">Todos</option>
                    <option value="Pendente">Pendente</option>
                    <option value="OK">OK</option>
                    <option value="Contestada">Contestada</option>
                </select>
            </div>
            <div>
                <label class="form-label small mb-1">Colaborador</label>
                <input type="text" class="form-control form-control-sm" placeholder="Buscar..." @bind="filtroColaborador"
                       @bind:after="Filtrar" />
            </div>
            <div>
                <span class="badge bg-secondary align-self-center">
                    @viagensFiltradas.Count viagem(ns)
                </span>
            </div>
        </div>
    </div>

    @if (mesEncerradoParaGestor)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2">
            <Icon Name="lock" Size="16" />
            <span>
                <strong>Mês encerrado!</strong> O mês de
                @System.Globalization.CultureInfo.GetCultureInfo("pt-BR").DateTimeFormat.GetMonthName(mesSelecionado)/@anoSelecionado
                foi encerrado@(nomeQuemEncerrou is not null ? $" por {nomeQuemEncerrou}" : "").
                Não é possível atestar ou contestar viagens deste período.
            </span>
        </div>
    }

    <!-- Resumo -->
    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="card text-center border-warning">
                <div class="card-body py-2">
                    <div class="fs-3 fw-bold text-warning">@viagens.Count(v => v.StatusConferenciaGestor == "Pendente")
                    </div>
                    <small class="text-muted">Pendentes</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-success">
                <div class="card-body py-2">
                    <div class="fs-3 fw-bold text-success">@viagens.Count(v => v.StatusConferenciaGestor == "OK")</div>
                    <small class="text-muted">Aprovadas</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-danger">
                <div class="card-body py-2">
                    <div class="fs-3 fw-bold text-danger">@viagens.Count(v => v.StatusConferenciaGestor == "Contestada")
                    </div>
                    <small class="text-muted">Contestadas</small>
                </div>
            </div>
        </div>
    </div>

    @if (viagensFiltradas.Count == 0)
    {
        <div class="alert alert-info">Nenhuma viagem encontrada com os filtros selecionados.</div>
    }
    <!-- Paginação: seletor de itens por página -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="d-flex align-items-center gap-2">
            <small class="text-muted">Exibir</small>
            <select class="form-select form-select-sm filter-select" style="width: auto;" @bind="itensPorPagina"
                    @bind:after="OnPageSizeChanged">
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="30">30</option>
                <option value="50">50</option>
            </select>
            <small class="text-muted">viagens por página</small>
        </div>
        <small class="text-muted">
            Página @paginaAtual de @totalPaginas &mdash; @viagensFiltradas.Count viagem(ns)
        </small>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th class="text-center" role="button" @onclick="AlternarOrdemData" style="cursor:pointer;">
                        Início da Viagem @(ordenarDataAsc ? "▲" : "▼")
                    </th>
                    <th class="text-center">Fim da Viagem</th>
                    <th class="text-center">Colaborador</th>
                    <th class="text-center">Origem</th>
                    <th class="text-center">Destino</th>
                    <th class="text-center">Motivo da Viagem</th>
                    <th class="text-center">Parceiro</th>
                    <th class="text-center">Valor Final</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Ateste da viagem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in viagensPaginadas)
                {
                    <tr>
                        <td class="text-center">
                            @v.DataViagem.ToString("dd/MM/yyyy")<br />
                            @v.HoraInicio.ToString("HH:mm")
                        </td>
                        <td class="text-center">
                            @CalcDataFim(v).ToString("dd/MM/yyyy")<br />
                            @v.HoraFim.ToString("HH:mm")
                        </td>
                        <td class="text-center">@v.Colaborador.Nome</td>
                        <td class="text-center">@v.Origem</td>
                        <td class="text-center">@v.Destino</td>
                        <td class="text-center">@v.Motivo</td>
                        <td class="text-center">@v.Parceiro.Nome</td>
                        <td class="text-center">R$ @v.ValorFinal.ToString("N2")</td>
                        <td class="text-center">
                            @switch (v.StatusConferenciaGestor)
                            {
                                case "Pendente":
                                    <span class="badge bg-warning text-dark">
                                        <Icon Name="clock" Size="12" /> Pendente
                                    </span>
                                    break;
                                case "OK":
                                    <span class="badge bg-success">
                                        <Icon Name="circle-check" Size="12" /> Atestada
                                    </span>
                                    break;
                                case "Contestada":
                                    <button type="button"
                                            class="badge bg-danger border-0 d-inline-flex align-items-center gap-1 btn-badge-contestada"
                                            style="cursor: pointer; user-select: none;" @onclick="() => MostrarMotivoContestacao(v)"
                                            title="Clique para ver o motivo da contestação">
                                        <Icon Name="circle-xmark" Size="12" /> Contestada
                                    </button>
                                    break;
                            }
                        </td>
                        <td class="text-center">
                            @if (isSomenteLeitura)
                            {
                                <span class="text-muted small">Sem permissão</span>
                            }
                            else
                            {
                                @if (v.StatusConferenciaGestor == "Pendente")
                                {
                                    <button class="btn btn-sm btn-success me-1" @onclick="() => Aprovar(v)">
                                        <Icon Name="circle-check" Size="14" /> Atestar
                                    </button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => AbrirContestacao(v)">
                                        <Icon Name="circle-xmark" Size="14" /> Contestar
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => SolicitarReversao(v)">
                                        <Icon Name="rotate-left" Size="14" /> Reverter
                                    </button>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Navegação de páginas -->
    @if (totalPaginas > 1)
    {
        <nav>
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(paginaAtual == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => IrParaPagina(paginaAtual - 1)">&laquo;</button>
                </li>
                @for (int i = 1; i <= totalPaginas; i++)
                {
                    var pg = i;
                    <li class="page-item @(pg == paginaAtual ? "active" : "")">
                        <button class="page-link" @onclick="() => IrParaPagina(pg)">@pg</button>
                    </li>
                }
                <li class="page-item @(paginaAtual == totalPaginas ? "disabled" : "")">
                    <button class="page-link" @onclick="() => IrParaPagina(paginaAtual + 1)">&raquo;</button>
                </li>
            </ul>
        </nav>
    }

    <!-- Confirmação Mensal -->
    @if (viagens is not null && viagens.Count > 0)
    {
        <div class="card shadow-sm mt-4">
            <div class="card-body">
                @if (jaConfirmou && viagens.Any(v => v.StatusConferenciaGestor == "Pendente"))
                {
                    <div class="alert alert-danger mb-0">
                        <Icon Name="triangle-exclamation" Size="16" Class="text-danger me-1" />
                        <strong>Novas Pendências!</strong> Novas viagens foram importadas para este mês após a confirmação realizada
                        por
                        <strong>@confirmadoPorNome</strong> em @confirmadoEm?.ToString("dd/MM/yyyy HH:mm").
                        Analise as novas viagens pendentes na tabela acima para poder reconfirmar o mês.
                    </div>
                }
                else if (jaConfirmou && confirmadoPorNome is not null)
                {
                    <div class="alert alert-success mb-0">
                        <Icon Name="circle-check" Size="16" Class="text-success me-1" /> Verificação de
                        <strong>@($"{mesSelecionado:D2}/{anoSelecionado}")</strong> confirmada por
                        <strong>@confirmadoPorNome</strong> em @confirmadoEm?.ToString("dd/MM/yyyy HH:mm")
                    </div>
                }
                else if (jaConfirmou)
                {
                    <div class="alert alert-success mb-0">
                        <Icon Name="circle-check" Size="16" Class="text-success me-1" /> Verificação do mês
                        <strong>@($"{mesSelecionado:D2}/{anoSelecionado}")</strong> já foi confirmada.
                    </div>
                }
                else if (todasVerificadas)
                {
                    <div class="alert alert-info mb-2">
                        Todas as viagens foram analisadas! Confirme a verificação do mês.
                    </div>
                    <button class="btn btn-success" @onclick="ConfirmarMes" disabled="@(confirmando || isSomenteLeitura)">
                        @if (confirmando)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <Icon Name="circle-check" Size="14" /> Confirmar Verificação de @($"{mesSelecionado:D2}/{anoSelecionado}")
                    </button>
                }
                else
                {
                    <div class="alert alert-warning mb-0">
                        <Icon Name="clock" Size="16" Class="text-warning me-1" /> Ainda há <strong>@viagens.Count(v =>
                                        v.StatusConferenciaGestor == "Pendente")</strong> viagem(ns)
                        pendente(s). Analise todas para poder confirmar o mês.
                    </div>
                }
            </div>
        </div>
    }
}

@* Modal de contestação *@
@if (viagemContestar is not null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Contestar Viagem</h5>
                    <button type="button" class="btn-close" @onclick="FecharContestacao"></button>
                </div>
                <div class="modal-body">
                    <p>
                        Viagem de <strong>@viagemContestar.Colaborador.Nome</strong>
                        em @viagemContestar.DataViagem.ToString("dd/MM/yyyy")
                        — R$ @viagemContestar.ValorFinal.ToString("N2")
                    </p>
                    <div class="mb-3">
                        <label class="form-label">Motivo da contestação</label>
                        <textarea class="form-control" rows="3" @bind="motivoContestacao"
                                  placeholder="Descreva o motivo..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="FecharContestacao">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ConfirmarContestacao"
                            disabled="@string.IsNullOrWhiteSpace(motivoContestacao)">
                        Confirmar Contestação
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Modal para exibir o motivo de contestação *@
@if (viagemMotivoMostrar is not null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title d-flex align-items-center gap-2">
                        <Icon Name="circle-xmark" Size="18" /> Motivo da Contestação
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FecharMotivoContestacao"></button>
                </div>
                <div class="modal-body text-start">
                    <p class="mb-3 small text-muted">
                        Viagem de <strong>@viagemMotivoMostrar.Colaborador.Nome</strong>
                        em @viagemMotivoMostrar.DataViagem.ToString("dd/MM/yyyy")
                        — Valor: R$ @viagemMotivoMostrar.ValorFinal.ToString("N2")
                    </p>
                    <div class="p-3 bg-light rounded border">
                        <p class="mb-0 text-dark fw-medium text-wrap" style="white-space: pre-wrap; text-align: left;">
                            @viagemMotivoMostrar.MotivoContestacao
                        </p>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-secondary btn-sm" @onclick="FecharMotivoContestacao">Fechar</button>
                </div>
            </div>
        </div>
    </div>
}

@* Modal de Confirmação de Reversão de Contestação *@
@if (viagemReverterConfirmar is not null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title d-flex align-items-center gap-2 fw-bold">
                        <Icon Name="triangle-exclamation" Size="18" /> Confirmar Reversão
                    </h5>
                    <button type="button" class="btn-close" @onclick="FecharReversaoConfirmar"></button>
                </div>
                <div class="modal-body text-start">
                    <p class="mb-3">
                        Você está prestes a reverter a contestação desta viagem.
                        Ao fazer isso, o motivo abaixo será <strong>excluído permanentemente</strong>:
                    </p>
                    <div class="p-3 bg-light rounded border mb-3">
                        <p class="mb-0 text-muted small">
                            Viagem de <strong>@viagemReverterConfirmar.Colaborador.Nome</strong> — Valor: R$
                            @viagemReverterConfirmar.ValorFinal.ToString("N2")
                        </p>
                        <hr class="my-2" />
                        <p class="mb-0 text-dark fw-semibold text-wrap" style="white-space: pre-wrap; text-align: left;">
                            @viagemReverterConfirmar.MotivoContestacao
                        </p>
                    </div>
                    <p class="text-danger fw-bold mb-0 small">
                        Deseja realmente reverter e apagar o motivo da contestação?
                    </p>
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-secondary btn-sm" @onclick="FecharReversaoConfirmar">Cancelar</button>
                    <button class="btn btn-warning btn-sm fw-bold text-dark" @onclick="ConfirmarReversaoContestada">
                        <Icon Name="rotate-left" Size="12" /> Reverter e Excluir
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool temPermissao;
    private List<Viagem>? viagens;
    private List<Viagem> viagensFiltradas = new();

    private List<CentroCusto> centrosCusto = new();
    private int? centroCustoSelecionadoId;
    private bool isAdmin;
    private bool isSomenteLeitura = false;
    private bool mesEncerradoParaGestor = false;
    private string? nomeQuemEncerrou;

    private int mesSelecionado = DateTime.Now.Month;
    private int anoSelecionado = DateTime.Now.Year;
    private List<int> anosDisponiveis = new();

    private string filtroStatus = "";
    private string filtroColaborador = "";

    private Viagem? viagemContestar;
    private string motivoContestacao = "";
    private Viagem? viagemMotivoMostrar;
    private Viagem? viagemReverterConfirmar;

    private bool jaConfirmou;
    private bool todasVerificadas;
    private bool confirmando;
    private string? confirmadoPorNome;
    private DateTime? confirmadoEm;

    // Ordenação e paginação
    private bool ordenarDataAsc;
    private int itensPorPagina = 10;
    private int paginaAtual = 1;
    private int totalPaginas => (int)Math.Ceiling((double)viagensFiltradas.Count / itensPorPagina);
    private List<Viagem> viagensPaginadas => viagensFiltradas
        .Skip((paginaAtual - 1) * itensPorPagina)
        .Take(itensPorPagina)
        .ToList();

    private async Task MesAnterior()
    {
        if (mesSelecionado > 1)
        {
            mesSelecionado--;
            await CarregarViagens();
        }
    }

    private async Task MesSeguinte()
    {
        if (mesSelecionado < 12)
        {
            mesSelecionado++;
            await CarregarViagens();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!UserSession.IsAuthenticated)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        var perfil = UserSession.UsuarioLogado!.Perfil;
        var temPermissaoPadrao = await Db.PerfisRecurso
            .AnyAsync(pr => pr.Perfil == perfil && pr.Recurso.Chave == "AnalisarViagens");

        isAdmin = perfil == "Admin" || perfil == "Gestor Central Ateste";
        temPermissao = temPermissaoPadrao || isAdmin;

        if (!temPermissao) return;

        if (isAdmin)
        {
            centrosCusto = await Db.CentrosCusto.OrderBy(c => c.Nome).ToListAsync();
        }

        centroCustoSelecionadoId = UserSession.UsuarioLogado!.CentroCustoId;

        anosDisponiveis = await Db.Viagens.Select(v => v.DataViagem.Year).Distinct().OrderByDescending(y => y).ToListAsync();
        if (anosDisponiveis.Count == 0 || !anosDisponiveis.Contains(DateTime.Now.Year))
            anosDisponiveis.Insert(0, DateTime.Now.Year);
        anosDisponiveis = anosDisponiveis.Distinct().OrderByDescending(y => y).ToList();

        await CarregarViagens();
    }

    private async Task CarregarViagens()
    {
        var centroCustoId = isAdmin ? centroCustoSelecionadoId : UserSession.UsuarioLogado!.CentroCustoId;

        var perfil = UserSession.UsuarioLogado!.Perfil;
        if (perfil == "Gestor Central Ateste" && centroCustoId != UserSession.UsuarioLogado!.CentroCustoId)
        {
            isSomenteLeitura = true;
        }
        else
        {
            isSomenteLeitura = false;
        }

        // Verificar encerramento do mês para gestores comuns
        mesEncerradoParaGestor = false;
        nomeQuemEncerrou = null;
        if (perfil == "Gestor Primário" || perfil == "Gestor Secundário")
        {
            var encerramento = await Db.EncerramentosMensais
                .Include(e => e.EncerradoPor)
                .FirstOrDefaultAsync(e => e.Ano == anoSelecionado && e.Mes == mesSelecionado && e.Encerrado);
            if (encerramento is not null)
            {
                mesEncerradoParaGestor = true;
                isSomenteLeitura = true;
                nomeQuemEncerrou = encerramento.EncerradoPor?.Nome;
            }
        }

        // Filtro por mês/ano
        var mesInicio = new DateOnly(anoSelecionado, mesSelecionado, 1);
        var mesFim = mesInicio.AddMonths(1);

        var query = Db.Viagens
            .Include(v => v.Colaborador)
            .Include(v => v.Parceiro)
            .Include(v => v.CentroCusto)
            .Where(v => v.DataViagem >= mesInicio && v.DataViagem < mesFim);

        // Se o gestor tem centro de custo selecionado ou definido no perfil, filtra; admin vê tudo caso deixe nulo
        if (centroCustoId.HasValue)
        {
            query = query.Where(v => v.CentroCustoId == centroCustoId.Value);
        }

        viagens = await query
            .OrderByDescending(v => v.DataViagem)
            .ThenBy(v => v.StatusConferenciaGestor)
            .ToListAsync();

        Filtrar();
        await VerificarConfirmacao();
    }

    private async Task VerificarConfirmacao()
    {
        var centroCustoId = isAdmin ? centroCustoSelecionadoId : UserSession.UsuarioLogado!.CentroCustoId;
        if (!centroCustoId.HasValue || viagens is null) return;

        var conferencia = await Db.ConferenciasMensais
            .Include(c => c.Usuario)
            .FirstOrDefaultAsync(c => c.CentroCustoId == centroCustoId.Value && c.Ano == anoSelecionado && c.Mes == mesSelecionado);

        jaConfirmou = conferencia is not null;
        confirmadoPorNome = conferencia?.Usuario.Nome;
        confirmadoEm = conferencia?.DataConfirmacao;

        todasVerificadas = viagens.Count > 0 && viagens.All(v => v.StatusConferenciaGestor != "Pendente");
    }

    private void Filtrar()
    {
        if (viagens is null) return;

        var resultado = viagens
            .Where(v => string.IsNullOrEmpty(filtroStatus) || v.StatusConferenciaGestor == filtroStatus)
            .Where(v => string.IsNullOrEmpty(filtroColaborador) ||
                        v.Colaborador.Nome.Contains(filtroColaborador, StringComparison.OrdinalIgnoreCase));

        viagensFiltradas = ordenarDataAsc
            ? resultado.OrderBy(v => v.DataViagem).ToList()
            : resultado.OrderByDescending(v => v.DataViagem).ToList();

        // Resetar página se necessário
        if (paginaAtual > totalPaginas && totalPaginas > 0) paginaAtual = totalPaginas;
        if (paginaAtual < 1) paginaAtual = 1;
    }

    private void AlternarOrdemData()
    {
        ordenarDataAsc = !ordenarDataAsc;
        Filtrar();
    }

    /// Calcula a data de término da viagem.
    /// Se HoraFim HoraInicio, a viagem cruzou a meia-noite e terminou no= dia seguinte
    private static DateOnly CalcDataFim(Viagem v)
    {
        return v.HoraFim < v.HoraInicio
            ? v.DataViagem.AddDays(1)
            : v.DataViagem;
    }

    private void IrParaPagina(int pagina)
    {
        if (pagina >= 1 && pagina <= totalPaginas)
            paginaAtual = pagina;
    }

    private void OnPageSizeChanged()
    {
        paginaAtual = 1;
        Filtrar();
    }



    private async Task Aprovar(Viagem v)
    {
        v.StatusConferenciaGestor = "OK";
        v.DataConferencia = DateTime.Now;
        v.MotivoContestacao = null;
        await Db.SaveChangesAsync();
        await InvalidarConfirmacao();
        Filtrar();
        await VerificarConfirmacao();
    }

    private void AbrirContestacao(Viagem v)
    {
        viagemContestar = v;
        motivoContestacao = "";
    }

    private void FecharContestacao()
    {
        viagemContestar = null;
        motivoContestacao = "";
    }

    private void MostrarMotivoContestacao(Viagem v)
    {
        viagemMotivoMostrar = v;
    }

    private void FecharMotivoContestacao()
    {
        viagemMotivoMostrar = null;
    }

    private async Task ConfirmarContestacao()
    {
        if (viagemContestar is null || string.IsNullOrWhiteSpace(motivoContestacao)) return;

        viagemContestar.StatusConferenciaGestor = "Contestada";
        viagemContestar.DataConferencia = DateTime.Now;
        viagemContestar.MotivoContestacao = motivoContestacao;
        await Db.SaveChangesAsync();

        FecharContestacao();
        await InvalidarConfirmacao();
        Filtrar();
        await VerificarConfirmacao();
    }

    private async Task Reverter(Viagem v)
    {
        v.StatusConferenciaGestor = "Pendente";
        v.DataConferencia = null;
        v.MotivoContestacao = null;
        await Db.SaveChangesAsync();
        await InvalidarConfirmacao();
        Filtrar();
        await VerificarConfirmacao();
    }

    private async Task SolicitarReversao(Viagem v)
    {
        if (v.StatusConferenciaGestor == "Contestada")
        {
            viagemReverterConfirmar = v;
        }
        else
        {
            await Reverter(v);
        }
    }

    private async Task ConfirmarReversaoContestada()
    {
        if (viagemReverterConfirmar is null) return;
        var v = viagemReverterConfirmar;
        viagemReverterConfirmar = null;
        await Reverter(v);
    }

    private void FecharReversaoConfirmar()
    {
        viagemReverterConfirmar = null;
    }

    /// Remove a confirmação existente deste centro de custo/mês para forçar reconfirmação
    private async Task InvalidarConfirmacao()
    {
        var centroCustoId = isAdmin ? centroCustoSelecionadoId : UserSession.UsuarioLogado!.CentroCustoId;
        if (!centroCustoId.HasValue) return;

        var conf = await Db.ConferenciasMensais
            .FirstOrDefaultAsync(c => c.CentroCustoId == centroCustoId.Value && c.Ano == anoSelecionado && c.Mes == mesSelecionado);

        if (conf is not null)
        {
            Db.ConferenciasMensais.Remove(conf);
            await Db.SaveChangesAsync();
        }
    }

    private async Task ConfirmarMes()
    {
        var centroCustoId = isAdmin ? centroCustoSelecionadoId : UserSession.UsuarioLogado!.CentroCustoId;
        if (!centroCustoId.HasValue) return;

        confirmando = true;
        try
        {
            var conferencia = new ConferenciaMensal
            {
                CentroCustoId = centroCustoId.Value,
                Ano = anoSelecionado,
                Mes = mesSelecionado,
                UsuarioId = UserSession.UsuarioLogado!.Id,
                DataConfirmacao = DateTime.Now
            };
            Db.ConferenciasMensais.Add(conferencia);
            await Db.SaveChangesAsync();
            jaConfirmou = true;
        }
        finally
        {
            confirmando = false;
        }
    }
}
