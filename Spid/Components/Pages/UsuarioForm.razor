@page "/usuarios/novo"
@page "/usuarios/editar/{IdUsuario:int}"
@using Microsoft.EntityFrameworkCore
@using Spid.Data
@inject AppDbContext Db
@inject UserSession UserSession
@inject NavigationManager Nav

<PageTitle>@(editando ? "Editar" : "Novo") Usuário — SPID</PageTitle>

<h3 class="mb-4">@if (editando) {
    <Icon Name="user-pen" Size="24" Class="page-header-icon" /> <text>Editar Usuário</text>
} else
{
    <Icon Name="user-plus" Size="24" Class="page-header-icon" /> <text>Novo Usuário</text>
}
</h3>

@if (!isAdmin)
{
    <div class="alert alert-warning">Você não tem permissão para acessar esta página.</div>
}
else
{
    @if (!string.IsNullOrEmpty(erro))
    {
        <div class="alert alert-danger">@erro</div>
    }

    @if (!string.IsNullOrEmpty(sucesso))
    {
        <div class="alert alert-success">@sucesso</div>
    }

    <div class="card shadow-sm" style="max-width: 600px;">
        <div class="card-body">
            <EditForm Model="this" OnValidSubmit="Salvar">
                <div class="mb-3">
                    <label class="form-label">Nome completo</label>
                    <InputText @bind-Value="nome" class="form-control" placeholder="Ex: João Silva" />
                </div>

                <div class="mb-3">
                    <label class="form-label">E-mail</label>
                    <InputText @bind-Value="email" class="form-control" placeholder="Ex: joaoexemplo@gmail.com" />
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label">Ponto (login)</label>
                        <InputText @bind-Value="ponto" class="form-control" placeholder="Ex: P_******" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">CPF</label>
                        <InputText @bind-Value="cpf" class="form-control" placeholder="000.000.000-00" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label">Perfil</label>
                        <InputSelect @bind-Value="grupoPerfil" class="form-select" @bind-Value:after="OnGrupoPerfilChanged" disabled="@(editando && UserSession.UsuarioLogado!.Perfil == "Gestor Central Padrão")">
                            <option value="">Selecione...</option>
                            @if (isAdmin)
                            {
                                @if (UserSession.UsuarioLogado!.Perfil == "Admin")
                                {
                                    <option value="Admin">Admin</option>
                                }
                                <option value="Gestor">Gestor</option>
                                <option value="Gestor Central">Gestor Central</option>
                            }
                            else
                            {
                                <option value="Colaborador">Colaborador</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Tipo de Gestor</label>
                        <InputSelect @bind-Value="subtipoPerfil" class="form-select"
                                     disabled="@((editando && UserSession.UsuarioLogado!.Perfil == "Gestor Central Padrão") || (grupoPerfil != "Gestor" && grupoPerfil != "Gestor Central"))">
                            <option value="">Selecione...</option>
                            @if (grupoPerfil == "Gestor")
                            {
                                <option value="Titular">Titular</option>
                                <option value="Substituto">Substituto</option>
                            }
                            else if (grupoPerfil == "Gestor Central")
                            {
                                <option value="Padrão">Padrão</option>
                                @if (UserSession.UsuarioLogado!.Perfil == "Admin" || UserSession.UsuarioLogado!.Perfil ==
              "Gestor Central Ateste")
                                {
                                    <option value="Ateste">Ateste</option>
                                }
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Centro de Custo</label>
                    <InputSelect @bind-Value="centroCustoId" class="form-select"
                                 disabled="@(grupoPerfil != "Gestor" && grupoPerfil != "Colaborador" && (grupoPerfil != "Gestor Central" || subtipoPerfil != "Ateste"))">
                        <option value="0">Selecione...</option>
                        @if (centrosCusto is not null)
                        {
                            @foreach (var s in centrosCusto)
                            {
                                <option value="@s.Id">@s.Nome</option>
                            }
                        }
                    </InputSelect>
                </div>

                @if (editando)
                {
                    <div class="mb-3">
                        <label class="form-label">Nova senha (deixe em branco para manter)</label>
                        <InputText @bind-Value="senha" type="password" class="form-control" placeholder="••••••••" />
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-3">
                        <small>A senha inicial será definida automaticamente como o <strong>Ponto</strong> do usuário. No
                            primeiro login, ele será solicitado a criar uma nova senha.</small>
                        </div>
                    }

                    <div class="mb-3 d-flex justify-content-between align-items-center">
                        <div class="form-check">
                            <InputCheckbox @bind-Value="ativo" class="form-check-input" id="ativoCheck" />
                            <label class="form-check-label" for="ativoCheck">Usuário ativo</label>
                        </div>
                        @if (editando && IdUsuario != UserSession.UsuarioLogado?.Id && UserSession.UsuarioLogado?.Perfil ==
                "Admin")
                        {
                            <button type="button" class="btn btn-outline-danger btn-sm"
                                    @onclick="() => exibindoConfirmacaoExclusao = true">
                                <Icon Name="trash" Size="14" /> Excluir Usuário
                            </button>
                        }
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@salvando">
                            @if (salvando)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            @(editando ? "Salvar Alterações" : "Criar Usuário")
                        </button>
                        <a href="/usuarios" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (exibindoConfirmacaoExclusao)
    {
        <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">Confirmar Exclusão Permanente</h5>
                        <button type="button" class="btn-close btn-close-white"
                                @onclick="() => exibindoConfirmacaoExclusao = false"></button>
                    </div>
                    <div class="modal-body">
                        <p>Tem certeza que deseja <strong>excluir permanentemente</strong> o usuário <strong>@nome</strong> do
                            sistema?</p>
                            <p class="text-danger small">
                                <Icon Name="triangle-exclamation" /> Esta ação não pode ser desfeita e pode falhar se o usuário
                                possuir registros vinculados (viagens, logs, etc).
                            </p>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="() => exibindoConfirmacaoExclusao = false">Cancelar</button>
                            <button class="btn btn-danger" @onclick="ExcluirUsuario" disabled="@salvando">
                                @if (salvando)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Confirmar Exclusão
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

@code {
    [Parameter] public int IdUsuario { get; set; }

    private bool isAdmin;
    private bool editando;
    private bool salvando;
    private string? erro;
    private string? sucesso;
    private bool exibindoConfirmacaoExclusao;

    private string nome = "";
    private string email = "";
    private string ponto = "";
    private string? cpf;
    private string grupoPerfil = "";
    private string subtipoPerfil = "";
    private int centroCustoId;
    private string senha = "";
    private bool ativo = true;

    private List<CentroCusto>? centrosCusto;
    private Usuario? usuarioEditando;

    protected override async Task OnInitializedAsync()
    {
        if (!UserSession.IsAuthenticated)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        isAdmin = UserSession.UsuarioLogado!.Perfil == "Admin" || UserSession.UsuarioLogado!.Perfil.StartsWith("Gestor Central");
        if (!isAdmin) return;

        centrosCusto = await Db.CentrosCusto.OrderBy(s => s.Nome).ToListAsync();

        if (IdUsuario > 0)
        {
            editando = true;
            usuarioEditando = await Db.Usuarios.FindAsync(IdUsuario);

            if (usuarioEditando is null)
            {
                Nav.NavigateTo("/usuarios");
                return;
            }

            var perfilLogado = UserSession.UsuarioLogado!.Perfil;
            var perfilAlvo = usuarioEditando.Perfil;
            bool eEleMesmo = UserSession.UsuarioLogado!.Id == usuarioEditando.Id;

            bool podeEditar = eEleMesmo || perfilLogado == "Admin" ||
                             (perfilLogado == "Gestor Central Ateste" && perfilAlvo != "Admin" && perfilAlvo != "Gestor Central Ateste") ||
                             (perfilLogado == "Gestor Central Padrão" && (perfilAlvo == "Gestor Titular" || perfilAlvo == "Gestor Substituto"));
            
            if (!podeEditar)
            {
                Nav.NavigateTo("/usuarios");
                return;
            }

            nome = usuarioEditando.Nome;
            email = usuarioEditando.Email;
            ponto = usuarioEditando.Ponto;
            cpf = usuarioEditando.Cpf;

            if (usuarioEditando.Perfil == "Admin" || usuarioEditando.Perfil == "Colaborador")
            {
                grupoPerfil = usuarioEditando.Perfil;
                subtipoPerfil = "";
            }
            else if (usuarioEditando.Perfil.StartsWith("Gestor Central "))
            {
                grupoPerfil = "Gestor Central";
                subtipoPerfil = usuarioEditando.Perfil.Replace("Gestor Central ", "");
            }
            else if (usuarioEditando.Perfil.StartsWith("Gestor "))
            {
                grupoPerfil = "Gestor";
                subtipoPerfil = usuarioEditando.Perfil.Replace("Gestor ", "");
            }

            centroCustoId = usuarioEditando.CentroCustoId ?? 0;
            ativo = usuarioEditando.Ativo;
        }
    }

    private void OnGrupoPerfilChanged()
    {
        subtipoPerfil = "";
        if (grupoPerfil == "Admin")
        {
            centroCustoId = 0;
        }
    }

    private void OnSubtipoPerfilChanged()
    {
        if (grupoPerfil == "Gestor Central" && subtipoPerfil == "Padrão")
        {
            centroCustoId = 0;
        }
    }

    private async Task Salvar()
    {
        erro = null;
        sucesso = null;
        salvando = true;

        try
        {
            // Validações
            if (string.IsNullOrWhiteSpace(nome) || string.IsNullOrWhiteSpace(ponto) || string.IsNullOrWhiteSpace(grupoPerfil))
            {
                erro = "Preencha Nome, Ponto e Perfil.";
                return;
            }

            if ((grupoPerfil == "Gestor" || grupoPerfil == "Gestor Central") && string.IsNullOrWhiteSpace(subtipoPerfil))
            {
                erro = "Selecione o tipo específico de Gestor.";
                return;
            }

            if (grupoPerfil == "Admin" && UserSession.UsuarioLogado!.Perfil != "Admin")
            {
                erro = "Apenas administradores podem criar ou editar perfis de Admin.";
                return;
            }

            if (grupoPerfil == "Gestor Central" && subtipoPerfil == "Ateste")
            {
                if (UserSession.UsuarioLogado!.Perfil != "Admin" && UserSession.UsuarioLogado!.Perfil != "Gestor Central Ateste")
                {
                    erro = "Apenas administradores e Gestores Centrais Ateste podem criar ou editar perfis de Gestor Central Ateste.";
                    return;
                }
            }

            var isGestorCentralPadrao = grupoPerfil == "Gestor Central" && subtipoPerfil == "Padrão";

            if (grupoPerfil != "Admin" && !isGestorCentralPadrao && centroCustoId <= 0)
            {
                erro = "É obrigatório selecionar um Centro de Custo para este perfil.";
                return;
            }

            if (grupoPerfil == "Admin" || isGestorCentralPadrao)
            {
                centroCustoId = 0; // Admin e Gestor Central Padrão não precisam de centro de custo
            }

            var perfilFinal = grupoPerfil;
            if (!string.IsNullOrWhiteSpace(subtipoPerfil))
            {
                perfilFinal = $"{grupoPerfil} {subtipoPerfil}";
            }

            bool eEleMesmoNoSalvar = editando && usuarioEditando?.Id == UserSession.UsuarioLogado?.Id;
            if (UserSession.UsuarioLogado!.Perfil == "Gestor Central Padrão" && perfilFinal != "Gestor Titular" && perfilFinal != "Gestor Substituto" && !eEleMesmoNoSalvar)
            {
                erro = "Gestores Centrais Padrão só podem gerenciar e criar perfis de Gestor Titular e Substituto.";
                return;
            }

            // Verificar ponto duplicado
            var idAtual = usuarioEditando?.Id ?? 0;
            var pontoDuplicado = await Db.Usuarios
                .AnyAsync(u => u.Ponto == ponto && u.Id != idAtual);
            if (pontoDuplicado)
            {
                erro = $"Já existe um usuário com o ponto \"{ponto}\".";
                return;
            }

            if (editando && usuarioEditando is not null)
            {
                usuarioEditando.Nome = nome;
                usuarioEditando.Email = email ?? "";
                usuarioEditando.Ponto = ponto;
                usuarioEditando.Cpf = cpf;
                
                if (UserSession.UsuarioLogado!.Perfil != "Gestor Central Padrão")
                {
                    usuarioEditando.Perfil = perfilFinal;
                }

                usuarioEditando.CentroCustoId = centroCustoId > 0 ? centroCustoId : null;
                usuarioEditando.Ativo = ativo;

                if (!string.IsNullOrWhiteSpace(senha))
                {
                    usuarioEditando.SenhaHash = UserSession.HashSenha(usuarioEditando, senha);
                }

                await Db.SaveChangesAsync();
                sucesso = "Usuário atualizado com sucesso!";
            }
            else
            {
                var novoUsuario = new Usuario
                {
                    Nome = nome,
                    Email = email ?? "",
                    Ponto = ponto,
                    Cpf = cpf,
                    Perfil = perfilFinal,
                    CentroCustoId = centroCustoId > 0 ? centroCustoId : null,
                    Ativo = ativo,
                    ContadorAcessos = 0
                };
                // Senha inicial = Ponto do usuário
                novoUsuario.SenhaHash = UserSession.HashSenha(novoUsuario, ponto);

                Db.Usuarios.Add(novoUsuario);
                await Db.SaveChangesAsync();
                sucesso = "Usuário criado com sucesso!";

                // Limpar campos
                nome = email = ponto = grupoPerfil = subtipoPerfil = "";
                cpf = null;
                centroCustoId = 0;
                ativo = true;
            }
        }
        catch (Exception ex)
        {
            erro = $"Erro ao salvar: {ex.Message}";
        }
        finally
        {
            salvando = false;
        }
    }

    private async Task ExcluirUsuario()
    {
        if (usuarioEditando is null) return;
        if (UserSession.UsuarioLogado?.Perfil != "Admin")
        {
            erro = "Apenas Administradores podem excluir usuários.";
            exibindoConfirmacaoExclusao = false;
            return;
        }

        salvando = true;
        erro = null;

        try
        {
            Db.Usuarios.Remove(usuarioEditando);
            await Db.SaveChangesAsync();
            Nav.NavigateTo("/usuarios");
        }
        catch (Exception)
        {
            erro = "Não foi possível excluir o usuário. Ele pode ter registros vinculados no sistema. Considere apenas inativá-lo.";
            exibindoConfirmacaoExclusao = false;
        }
        finally
        {
            salvando = false;
        }
    }
}
