@page "/"
@using Microsoft.EntityFrameworkCore
@using Spid.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject UserSession UserSession
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Dashboard — SPID</PageTitle>

@if (!UserSession.IsAuthenticated)
{
    <p class="text-muted">Redirecionando...</p>
}
else if (carregando)
{
    <div class="d-flex align-items-center gap-2 mt-4">
        <div class="spinner-border spinner-border-sm text-primary"></div>
        <span class="text-muted">Carregando dashboard...</span>
    </div>
}
else
{
    <!-- Cabeçalho com filtros -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <span class="dash-title"><Icon Name="chart-pie" Size="24" Class="page-header-icon" /> Visão Geral</span>

        <div class="d-flex align-items-center gap-2 flex-wrap">
            @if (setores.Count > 0)
            {
                <div class="d-flex align-items-center gap-1">
                    @if (isAdmin)
                    {
                        <button class="filter-btn" @onclick="SetorAnterior" disabled="@(!TemSetorAnterior())">&#9664;</button>
                    }
                    <select class="setor-select" @bind="setorSelecionadoId" @bind:after="CarregarDados" disabled="@(!isAdmin)">
                        @if (isAdmin)
                        {
                            <option value="">Todos os Centros de Custo</option>
                        }
                        @foreach (var s in setores)
                        {
                            <option value="@s.Id">@s.Nome</option>
                        }
                    </select>
                    @if (isAdmin)
                    {
                        <button class="filter-btn" @onclick="SetorSeguinte" disabled="@(!TemSetorSeguinte())">&#9654;</button>
                    }
                </div>
            }

            <div class="d-flex align-items-center gap-1">
                <button class="filter-btn" @onclick="MesAnterior" disabled="@(mesSelecionado <= 1)">&#9664;</button>
                <select class="filter-select" @bind="mesSelecionado" @bind:after="CarregarDados">
                    @for (int m = 1; m <= 12; m++)
                    {
                        var mes = m;
                        <option value="@mes">
                            @System.Globalization.CultureInfo.GetCultureInfo("pt-BR").DateTimeFormat.GetMonthName(mes)
                        </option>
                    }
                </select>
                <button class="filter-btn" @onclick="MesSeguinte" disabled="@(mesSelecionado >= 12)">&#9654;</button>
            </div>

            <div class="d-flex align-items-center gap-1">
                <select class="filter-select" @bind="anoSelecionado" @bind:after="CarregarDados">
                    @foreach (var a in anosDisponiveis)
                    {
                        <option value="@a">@a</option>
                    }
                </select>
            </div>
        </div>
        </div>

        <!-- KPI Cards -->
        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-lg-4">
                <div class="card kpi-card p-3 h-100">
                    <div class="d-flex align-items-center gap-3">
                        <div class="kpi-icon" style="background:#e8f0fe;color:#1a73e8;"><Icon Name="car" Size="24" /></div>
                        <div>
                            <div class="kpi-value">@totalCorridas</div>
                            <div class="kpi-label">Corridas realizadas</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="card kpi-card p-3 h-100">
                    <div class="d-flex align-items-center gap-3">
                        <div class="kpi-icon" style="background:#e6f4ea;color:#1e7e34;"><Icon Name="money-bill" Size="24" /></div>
                        <div>
                            <div class="kpi-value" style="color:#1e7e34;">R$ @custoTotal.ToString("N2")</div>
                            <div class="kpi-label">Custo total</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="card kpi-card p-3 h-100">
                    <div class="d-flex align-items-center gap-3">
                        <div class="kpi-icon" style="background:#fff3e0;color:#e65100;"><Icon Name="chart-line-up" Size="24" /></div>
                        <div>
                            <div class="kpi-value" style="color:#e65100;">R$ @ticketMedio.ToString("N2")</div>
                            <div class="kpi-label">Ticket médio</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Operadores + Gráfico -->
        <div class="row g-3">
            <!-- Operadores mais utilizados -->
            <div class="col-md-5">
                <div class="card chart-card p-3 h-100">
                    <div class="fw-semibold mb-3" style="color:#1a2340;">Operadores mais utilizados</div>
                    @if (topOperadores.Count == 0)
                    {
                        <p class="text-muted small">Nenhum dado para o período.</p>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-3">
                            @for (int i = 0; i < topOperadores.Count; i++)
                            {
                                var op = topOperadores[i];
                                var rank = i + 1;
                                var pct = totalCorridas > 0 ? (double)op.Corridas / totalCorridas * 100 : 0;
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="text-muted" style="font-size:.75rem;width:16px;">@rank&ordm;</span>
                                        <div class="operator-badge">@(op.Nome.Length >= 2 ? op.Nome[..2].ToUpper() : op.Nome.ToUpper())
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="fw-semibold" style="font-size:.875rem;">@op.Nome</div>
                                            <div class="text-muted" style="font-size:.75rem;">@op.Corridas corrida(s)</div>
                                        </div>
                                    </div>
                                    <div class="progress" style="height:5px;">
                                        <div class="progress-bar" style="width:@pct.ToString("F0")%;background:#1a73e8;"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Gráfico de corridas diárias -->
            <div class="col-md-7">
                <div class="card chart-card p-3 h-100">
                    <div class="fw-semibold mb-3" style="color:#1a2340;">Viagens diárias por empresa</div>
                    @if (totalCorridas == 0)
                    {
                        <p class="text-muted small">Nenhum dado para o período.</p>
                    }
                    else
                    {
                        <div class="chart-wrapper">
                            <canvas id="dashChart"></canvas>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

@code {
    // ── Estado ──────────────────────────────────────────────
    private bool carregando = true;
    private bool isAdmin;
    private int? setorSelecionadoId;

    private int mesSelecionado = DateTime.Now.Month;
    private int anoSelecionado = DateTime.Now.Year;

    private List<Setor> setores = new();
    private List<int> anosDisponiveis = new();

    // ── Navegação de Data ────────────────────────────────────
    private async Task MesAnterior()
    {
        if (mesSelecionado > 1)
        {
            mesSelecionado--;
            await CarregarDados();
        }
    }

    private async Task MesSeguinte()
    {
        if (mesSelecionado < 12)
        {
            mesSelecionado++;
            await CarregarDados();
        }
    }

    private bool TemSetorAnterior()
    {
        if (!isAdmin || setores.Count == 0) return false;
        return setorSelecionadoId != null;
    }

    private bool TemSetorSeguinte()
    {
        if (!isAdmin || setores.Count == 0) return false;
        if (setorSelecionadoId == null) return true;
        var index = setores.FindIndex(s => s.Id == setorSelecionadoId);
        return index >= 0 && index < setores.Count - 1;
    }

    private async Task SetorAnterior()
    {
        if (!TemSetorAnterior()) return;

        var index = setores.FindIndex(s => s.Id == setorSelecionadoId);
        if (index == 0)
            setorSelecionadoId = null;
        else if (index > 0)
            setorSelecionadoId = setores[index - 1].Id;

        await CarregarDados();
    }

    private async Task SetorSeguinte()
    {
        if (!TemSetorSeguinte()) return;

        if (setorSelecionadoId == null)
            setorSelecionadoId = setores[0].Id;
        else
        {
            var index = setores.FindIndex(s => s.Id == setorSelecionadoId);
            if (index >= 0 && index < setores.Count - 1)
                setorSelecionadoId = setores[index + 1].Id;
        }

        await CarregarDados();
    }

    // KPIs
    private int totalCorridas;
    private decimal custoTotal;
    private decimal ticketMedio;

    // Top operadores
    private List<OperadorItem> topOperadores = new();

    // Dados do gráfico — calculados junto com os KPIs, sem segunda query
    private string[] labelsGrafico = Array.Empty<string>();
    private List<DadosParceiro> datasetsGrafico = new();

    // Flag: sinaliza que o gráfico precisa ser re-renderizado no próximo AfterRender
    private bool chartPendente;

    record OperadorItem(string Nome, int Corridas);
    record DadosParceiro(string Label, int[] Data);

    // ── Lifecycle ────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        if (!UserSession.IsAuthenticated)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        var perfil = UserSession.UsuarioLogado!.Perfil;
        isAdmin = perfil == "Admin";

        // Contexto próprio — isolado do DbContext scoped do circuito
        await using (var db = DbFactory.CreateDbContext())
        {
            setores = await db.Setores.OrderBy(s => s.Nome).ToListAsync();
        }

        if (isAdmin)
        {
            setorSelecionadoId = null; // Padrão: Todos os Setores
        }
        else
        {
            setorSelecionadoId = UserSession.UsuarioLogado.SetorId;
        }

        await using (var db = DbFactory.CreateDbContext())
        {
            anosDisponiveis = await db.Viagens.Select(v => v.DataViagem.Year).Distinct().OrderByDescending(y => y).ToListAsync();
            if (anosDisponiveis.Count == 0 || !anosDisponiveis.Contains(DateTime.Now.Year))
                anosDisponiveis.Insert(0, DateTime.Now.Year);
            anosDisponiveis = anosDisponiveis.Distinct().OrderByDescending(y => y).ToList();
        }

        await CarregarDados();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Só renderiza o gráfico JS quando o canvas já está no DOM e há dados pendentes
        if (chartPendente && totalCorridas > 0)
        {
            chartPendente = false;
            await RenderizarGrafico();
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("destroyDashboardChart", "dashChart"); } catch { }
    }

    // ── Carga de dados ───────────────────────────────────────
    private async Task CarregarDados()
    {
        carregando = true;
        chartPendente = false;

        var mesInicio = new DateOnly(anoSelecionado, mesSelecionado, 1);
        var mesFim = mesInicio.AddMonths(1);
        int diasNoMes = DateTime.DaysInMonth(anoSelecionado, mesSelecionado);

        // Contexto próprio e de curta duração — sem conflito com NavMenu ou outros componentes
        await using var db = DbFactory.CreateDbContext();

        var query = db.Viagens
            .Include(v => v.Parceiro)
            .Where(v => v.DataViagem >= mesInicio && v.DataViagem < mesFim);

        if (setorSelecionadoId.HasValue)
            query = query.Where(v => v.SetorId == setorSelecionadoId.Value);

        var viagens = await query.ToListAsync();

        // KPIs
        totalCorridas = viagens.Count;
        custoTotal = viagens.Sum(v => v.ValorFinal);
        ticketMedio = totalCorridas > 0 ? custoTotal / totalCorridas : 0;

        // Top operadores
        topOperadores = viagens
            .GroupBy(v => v.Parceiro.Nome)
            .Select(g => new OperadorItem(g.Key, g.Count()))
            .OrderByDescending(x => x.Corridas)
            .Take(5)
            .ToList();

        // Dados para o gráfico (calculados em memória)
        labelsGrafico = Enumerable.Range(1, diasNoMes).Select(d => d.ToString()).ToArray();

        var operadores = viagens.Select(v => v.Parceiro.Nome).Distinct().OrderBy(x => x).ToList();
        datasetsGrafico = operadores.Select(op =>
        {
            var porDia = viagens
                .Where(v => v.Parceiro.Nome == op)
                .GroupBy(v => v.DataViagem.Day)
                .ToDictionary(g => g.Key, g => g.Count());

            var data = Enumerable.Range(1, diasNoMes)
                .Select(d => porDia.TryGetValue(d, out var cnt) ? cnt : 0)
                .ToArray();

            return new DadosParceiro(op, data);
        }).ToList();

        carregando = false;
        chartPendente = totalCorridas > 0;
    }

    // ── Gráfico — só interop JS, sem acesso ao banco ─────────
    private async Task RenderizarGrafico()
    {
        var datasets = datasetsGrafico
            .Select(d => new { label = d.Label, data = d.Data })
            .ToList();

        await JS.InvokeVoidAsync("renderDashboardChart", "dashChart", labelsGrafico, datasets, mesSelecionado);
    }
}